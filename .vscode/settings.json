{
    "cmake.buildDirectory": "${workspaceFolder}/build/${variant:board}-${variant:buildType}",
    "cmake.generator": "Ninja",
    "cmake.configureOnOpen": false,
    "cmake.options.statusBarVisibility": "compact",
    "cmake.options.advanced": {
        "build": {
            "statusBarVisibility": "visible",
            "inheritDefault": "hidden"
        },
        "launch": {
            "statusBarVisibility": "visible",
            "inheritDefault": "hidden"
        },
        "debug": {
            "statusBarVisibility": "visible",
            "inheritDefault": "hidden"
        },
        "cpack": {
            "statusBarVisibility": "hidden",
            "inheritDefault": "hidden"
        },
        "workflow": {
            "statusBarVisibility": "hidden",
            "inheritDefault": "hidden"
        }
    },
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.arguments": [
        // Switch compile-commands-dir and query-driver depending on target:
        // - host_build for unit tests
        // - build/NUCLEO_F767ZI-Develop and ARM query-driver for STM32 target

        // "--compile-commands-dir=build/NUCLEO_F767ZI-Develop",
        "--compile-commands-dir=host_build",
        "--background-index",
        "--clang-tidy",
        // "--query-driver=C:/arm-gcc/arm-none-eabi-gcc.bat"
    ],
    "yaml.schemas": {
        "file:///dev/null": "*.json"
    }
}